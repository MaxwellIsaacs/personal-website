#!/bin/bash

# Portfolio entry creation script
# Usage: new <type> <name> <time> <tags>
# Example: new project "6502 rust emulator" "2024-2025" "rust + asm"

set -e

# Check arguments
if [ $# -ne 4 ]; then
    echo "Usage: new <type> <name> <time> <tags>"
    echo "Types: work, project, dotfile"
    echo "Example: new project \"6502 rust emulator\" \"2024-2025\" \"rust + asm\""
    exit 1
fi

TYPE="$1"
NAME="$2"
TIME="$3"
TAGS="$4"

# Validate type
case "$TYPE" in
    work|project|dotfile)
        ;;
    *)
        echo "Error: Type must be 'work', 'project', or 'dotfile'"
        exit 1
        ;;
esac

# Convert type to script.js section name
case "$TYPE" in
    work)
        SECTION="work"
        ;;
    project)
        SECTION="projects"
        ;;
    dotfile)
        SECTION="dotfiles"
        ;;
esac

# Generate placeholder image path
IMAGE_NAME=$(echo "$NAME" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | sed 's/^-\|-$//g')
IMAGE_PATH="images/${IMAGE_NAME}.png"

# Create the new entry JSON
NEW_ENTRY="      {
        image: '${IMAGE_PATH}',
        title: '${NAME}',
        year: '${TIME}',
        tech: '${TAGS}',
        description: 'Description for ${NAME}.'
      }"

# Find the insertion point in script.js
SCRIPT_FILE="script.js"
if [ ! -f "$SCRIPT_FILE" ]; then
    echo "Error: script.js not found in current directory"
    exit 1
fi

# Create backup
cp "$SCRIPT_FILE" "${SCRIPT_FILE}.backup"

# Find the section and insert the new entry
# Look for the section header and find the cards array
SECTION_START=$(grep -n "^  ${SECTION}: {" "$SCRIPT_FILE" | cut -d: -f1)
if [ -z "$SECTION_START" ]; then
    echo "Error: Could not find ${SECTION} section in script.js"
    exit 1
fi

# Find the cards array start within this section
CARDS_START=$(tail -n +$SECTION_START "$SCRIPT_FILE" | grep -n "cards: \[" | head -1 | cut -d: -f1)
if [ -z "$CARDS_START" ]; then
    echo "Error: Could not find cards array in ${SECTION} section"
    exit 1
fi

CARDS_LINE=$((SECTION_START + CARDS_START - 1))

# Create a temporary file for the new content
TEMP_FILE=$(mktemp)

# Insert the new entry at the beginning of the cards array (most recent first)
head -n $CARDS_LINE "$SCRIPT_FILE" > "$TEMP_FILE"

# Add the new entry
echo "$NEW_ENTRY," >> "$TEMP_FILE"

# Add the rest of the file (skip the cards: [ line)
tail -n +$((CARDS_LINE + 1)) "$SCRIPT_FILE" >> "$TEMP_FILE"

# Replace the original file
mv "$TEMP_FILE" "$SCRIPT_FILE"

echo "✅ Added new ${TYPE}: \"${NAME}\" (${TIME})"
echo "📁 Placeholder image: ${IMAGE_PATH}"
echo "✏️  Edit the description in script.js as needed"
echo "🔄 Backup saved as: ${SCRIPT_FILE}.backup"

# Check if image exists
if [ ! -f "$IMAGE_PATH" ]; then
    echo "⚠️  Note: Image file ${IMAGE_PATH} does not exist yet"
fi